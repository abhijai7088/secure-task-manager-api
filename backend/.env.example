# Application
APP_NAME=Task Manager API
APP_VERSION=1.0.0
DEBUG=false

# Database
# For Docker (default): use PostgreSQL via the 'postgres' service
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/taskmanager
# For local development without Docker, uncomment below and comment the line above:
# DATABASE_URL=sqlite:///./taskmanager.db

# JWT — CHANGE THIS in production to a strong random secret
SECRET_KEY=change-this-to-a-strong-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin seed (optional — admin user is auto-created on startup if set)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
